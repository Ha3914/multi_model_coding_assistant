from typing import Literal
from pydantic import BaseModel, Field


class RepoFile(BaseModel):
    path: str = Field(..., description="仓库中的相对路径")
    content: str = Field(..., description="文件内容")


class RoleOverride(BaseModel):
    provider: str
    model: str


class AssistRequest(BaseModel):
    task: str = Field(..., min_length=3, description="开发者提出的编程任务")
    extra_context: str = Field(default="", description="额外上下文、报错信息、需求文档等")
    repo_files: list[RepoFile] = Field(default_factory=list, description="可选的仓库文件快照")
    language: str = Field(default="zh-CN", description="输出语言")
    temperature: float | None = Field(default=None, ge=0.0, le=1.5)
    role_overrides: dict[str, RoleOverride] = Field(default_factory=dict)


class StageResult(BaseModel):
    stage: str
    role: str
    provider: str
    model: str
    depends_on: list[str] = Field(default_factory=list)
    output: str


class AssistResponse(BaseModel):
    plan: list[str]
    stages: list[StageResult]
    final_answer: str


class HealthResponse(BaseModel):
    status: Literal["ok"] = "ok"
    app_name: str
    env: str
